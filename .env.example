# RedCardGenerator Backend Configuration
# Copy this file to .env and customize as needed

# ============================================
# PATH CONFIGURATION
# ============================================

# Path to the translations JSON file (absolute or relative to project root)
# CARD_TRANSLATIONS_JSON_PATH=./Translations.json

# Path to the fonts directory
# CARD_FONTS_DIR=./assets/fonts

# ============================================
# CORS CONFIGURATION
# ============================================

# Comma-separated list of allowed origins for CORS
# CARD_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ============================================
# PDF LAYOUT CONFIGURATION
# ============================================

# Default number of cards per page (4, 6, 8, or 12)
# CARD_DEFAULT_CARDS_PER_PAGE=4

# Page size: "letter" (8.5x11 inches) or "a4"
# CARD_PAGE_SIZE=letter

# Margins and spacing in inches
# CARD_MARGIN_INCHES=0.5
# CARD_GUTTER_INCHES=0.25
# CARD_FOOTER_HEIGHT_INCHES=0.55

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
# CARD_LOG_LEVEL=INFO
